{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "includeFiles": [
        "prisma/**",
        "node_modules/.prisma/client/**",
        "node_modules/@prisma/client/**"
      ]
    }
  },
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ]
}
